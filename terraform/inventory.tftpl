---
# Auto-generated Ansible inventory from Terraform
# Do not edit manually - managed by terraform/main.tf
all:
  hosts:
%{ for vm in vms ~}
    ${vm.name}:
      ansible_host: ${vm.ip}
%{ endfor ~}
  vars:
    ansible_user: ${ansible_user}
    ansible_ssh_common_args: '-o StrictHostKeyChecking=no'
