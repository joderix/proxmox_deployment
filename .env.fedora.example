# Fedora profile environment template
# Copy to .env.fedora and fill real values.
DEPLOY_ENV_FILE=.env.fedora
PROXMOX_URL=https://192.168.3.23:8006/api2/json
PROXMOX_API_TOKEN_ID=root@pam!ansible
PROXMOX_API_TOKEN_SECRET=your-api-token-secret-here
PROXMOX_NODE=pve03
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-key-here

# Optional: final Fedora template VMID created by Packer
PKR_VAR_template_vm_id=9104
