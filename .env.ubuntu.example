# Ubuntu profile environment template
# Copy to .env.ubuntu and fill real values.
DEPLOY_ENV_FILE=.env.ubuntu
PROXMOX_URL=https://192.168.3.23:8006/api2/json
PROXMOX_API_TOKEN_ID=root@pam!ansible
PROXMOX_API_TOKEN_SECRET=your-api-token-secret-here
PROXMOX_NODE=pve03
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-key-here

# Ubuntu cloud-image clone workflow:
# 1) Upload noble-server-cloud-amd64.img to Proxmox storage
# 2) Import it as a base cloud-image template VM and set its VMID below
PKR_VAR_base_cloud_image_vm_id=9002

# Optional: final Ubuntu template VMID created by Packer
PKR_VAR_template_vm_id=9204
